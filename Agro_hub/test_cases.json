[
    {
        "description": "Valid History Input - Single Crop",
        "input": {
            "history": [{"crop": "Wheat", "months": 4}]
        },
        "expected": "Success. Returns JSON with suggestions and current_soil_summary."
    },
    {
        "description": "Valid Manual Soil Input",
        "input": {
            "history": [],
